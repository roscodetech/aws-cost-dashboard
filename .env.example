# Credential resolution precedence:
#   1. AWS_PROFILE (named profile in ~/.aws/credentials)  <-- preferred
#   2. AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY (explicit keys)
#
# Use the dedicated READ-ONLY IAM user on the payer account. Never root.

# --- Option 1: named profile (recommended) ---
AWS_PROFILE=roscode-billing

# --- Option 2: explicit keys (used only if AWS_PROFILE is unset) ---
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# Cost Explorer endpoint region (do not change unless you know why)
AWS_REGION=us-east-1

# Cache time-to-live in seconds (default 1 hour). Refresh button always bypasses.
CACHE_TTL_SECONDS=3600

# Flask
FLASK_HOST=127.0.0.1
FLASK_PORT=5057
